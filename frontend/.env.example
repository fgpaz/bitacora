# Bitacora Frontend Environment Variables
# Copy to .env.local and fill with real values

# API base URL (backend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Supabase Auth — instancia dedicada a Bitácora
# Producción: https://auth.bitacora.nuestrascuentitas.com (instancia GoTrue propia)
# Dev local: puede apuntar a una instancia local de GoTrue
# NUNCA usar auth.tedi.nuestrascuentitas.com ni auth.nuestrascuentitas.com (son de otros productos)
NEXT_PUBLIC_SUPABASE_URL=https://auth.bitacora.nuestrascuentitas.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key-de-auth.bitacora.nuestrascuentitas.com>

# Optional: override for production
# NEXT_PUBLIC_API_BASE_URL=https://api.bitacora.nuestrascuentitas.com
