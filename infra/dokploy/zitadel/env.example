# Zitadel Teslita IdP — required env vars (reference)
#
# Values live in Infisical vault `teslita`, project `bitacora`, env `prod`.
# Pull with: `mkey pull bitacora prod`
#
# Never commit real values here — this file is a shape reference only.

# Version (pinned, never :latest)
ZITADEL_VERSION=v4.9.0
ZITADEL_POSTGRES_VERSION=17

# Core runtime
ZITADEL_MASTERKEY=                 # 32-byte base64 — NEVER rotate without re-encrypt DB
ZITADEL_EXTERNALDOMAIN=id.nuestrascuentitas.com
ZITADEL_EXTERNALPORT=443
ZITADEL_EXTERNALSECURE=true
ZITADEL_TLS_ENABLED=false          # Traefik terminates TLS upstream

# Database (dedicated, NOT Bitacora's Postgres)
ZITADEL_DATABASE_POSTGRES_HOST=postgres-reboot-wireless-panel-chhbwg
ZITADEL_DATABASE_POSTGRES_PORT=5432
ZITADEL_DATABASE_POSTGRES_DATABASE=shared_zitadel_v4
ZITADEL_DATABASE_POSTGRES_USER_USERNAME=zitadel
ZITADEL_DATABASE_POSTGRES_USER_PASSWORD=
ZITADEL_DATABASE_POSTGRES_USER_SSL_MODE=disable
ZITADEL_DATABASE_POSTGRES_ADMIN_USERNAME=zitadel
ZITADEL_DATABASE_POSTGRES_ADMIN_PASSWORD=
ZITADEL_DATABASE_POSTGRES_ADMIN_SSL_MODE=disable
ZITADEL_DATABASE_POSTGRES_ADMIN_EXISTINGDATABASE=postgres

# FirstInstance bootstrap (only effective on empty DB — data loss if re-bootstrap)
ZITADEL_FIRSTINSTANCE_PATPATH=/dev/stdout
ZITADEL_FIRSTINSTANCE_ORG_NAME=nuestrascuentitas
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_USERNAME=paz.fgabriel@gmail.com
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_EMAIL_ADDRESS=paz.fgabriel@gmail.com
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_EMAIL_VERIFIED=true
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD=
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORDCHANGEREQUIRED=false
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_USERNAME=zitadel-admin-sa
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_NAME=Admin Service Account
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_PAT_EXPIRATIONDATE=2099-12-31T23:59:59Z
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_PAT_SCOPES=openid
ZITADEL_FIRSTINSTANCE_ORG_LOGINCLIENT_MACHINE_USERNAME=login-client
ZITADEL_FIRSTINSTANCE_ORG_LOGINCLIENT_MACHINE_NAME=Login Client
ZITADEL_FIRSTINSTANCE_ORG_LOGINCLIENT_PAT_EXPIRATIONDATE=2099-12-31T23:59:59Z

# Admin access (post-bootstrap values)
ZITADEL_ADMIN_EMAIL=paz.fgabriel@gmail.com
ZITADEL_ADMIN_INITIAL_PASSWORD=
ZITADEL_ADMIN_PAT=                 # service account PAT, use as Bearer
ZITADEL_LOGIN_CLIENT_PAT=          # login companion service user PAT

# SMTP (Resend bridge, active post T2.2)
ZITADEL_SMTP_PROVIDER=resend
ZITADEL_SMTP_CONFIG_ID=            # Zitadel SMTP config id
ZITADEL_SMTP_SENDER_EMAIL=noreply@nuestrascuentitas.com

# Organizations + projects + OAuth clients (created in T2.1 + T2.4)
ZITADEL_ORG_NUESTRASCUENTITAS_ID=
ZITADEL_ORG_BITACORA_ID=
ZITADEL_ORG_MULTI_TEDI_ID=
ZITADEL_ORG_GASTOS_ID=
ZITADEL_PROJECT_NUESTRASCUENTITAS_ID=
ZITADEL_PROJECT_BITACORA_ID=
ZITADEL_PROJECT_MULTI_TEDI_ID=
ZITADEL_PROJECT_GASTOS_ID=
ZITADEL_CLIENT_NUESTRASCUENTITAS_WEB_ID=
ZITADEL_CLIENT_NUESTRASCUENTITAS_API_ID=
ZITADEL_CLIENT_NUESTRASCUENTITAS_API_SECRET=
ZITADEL_CLIENT_BITACORA_WEB_ID=
ZITADEL_CLIENT_BITACORA_API_ID=
ZITADEL_CLIENT_BITACORA_API_SECRET=
ZITADEL_CLIENT_MULTI_TEDI_WEB_ID=
ZITADEL_CLIENT_MULTI_TEDI_API_ID=
ZITADEL_CLIENT_MULTI_TEDI_API_SECRET=
ZITADEL_CLIENT_GASTOS_WEB_ID=
ZITADEL_CLIENT_GASTOS_API_ID=
ZITADEL_CLIENT_GASTOS_API_SECRET=

# Dokploy metadata (non-secret, trazability)
ZITADEL_DOKPLOY_PROJECT_ID=AKHsAJScexTwhJBzfFRlk
ZITADEL_DOKPLOY_APP_ID_WEB=zFdEECmPr1hhxwL0DKu4B
ZITADEL_DOKPLOY_APP_NAME_WEB=app-program-optical-matrix-xmjswe
ZITADEL_DOKPLOY_PG_ID_ACTIVE=BjjSOBWAwe6XpGttK4XoY
ZITADEL_DOKPLOY_PG_APP_NAME_ACTIVE=postgres-reboot-wireless-panel-chhbwg
ZITADEL_POSTGRES_VOLUME_NAME=postgres-reboot-wireless-panel-chhbwg-data
